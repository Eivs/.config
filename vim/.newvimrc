" ~/.vimrc

" -- General --
set nocompatible
set history=2000
set tm=500
set t_Co=256
set termguicolors

filetype on
filetype plugin on
filetype indent on

" -- Encoding --
set encoding=utf-8
set fileencodings=ucs-bom,utf-8,cp936,gb18030,big5,euc-jp,euc-kr,latin1
set fileformat=unix
set fileencoding=utf-8
set termencoding=utf-8
set ffs=unix,dos,mac
set formatoptions+=m
set formatoptions+=B

" -- Theme --
set background=dark
colorscheme snazzy

" -- Show --
syntax on
set number
set relativenumber
set ruler
set wrap
set sidescroll=1
set showcmd
set showmode
set showmatch
set matchtime=1
set cursorline
hi! link SignColumn   LineNr
hi! link ShowMarksHLl DiffAdd
hi! link ShowMarksHLu DiffChange

" -- Search --
set smartcase
set ignorecase
set incsearch
set hlsearch
" 双击 Esc 取消搜索高亮
nnoremap <Esc><Esc> :nohlsearch<CR>

" -- Tab --
set expandtab
set smarttab

" -- Indent --
set autoindent
set smartindent
set shiftround
set shiftwidth=4
set tabstop=4
set softtabstop=4

" -- Status Line --
set statusline=%<%f\ %h%m%r%=%k[%{(&fenc==\"\")?&enc:&fenc}%{(&bomb?\",BOM\":\"\")}]\ %-14.(%l,%c%V%)\ %P
set laststatus=2

" -- Select & Complete --
set selection=inclusive
set selectmode=mouse,key

" -- Behavior --
set scrolloff=5
set backspace=2
set mouse=a

" -- Clipboard --
set clipboard=unnamedplus
nnoremap y "+y
xnoremap y "+y
nnoremap yy "+yy
nnoremap Y "+y$

" -- Code Folding --
set foldlevelstart=99
set foldmethod=indent

" -- Undo --
set undofile
set undodir=~/.vim/undo

" -- Backup --
set nobackup
set nowritebackup
set noswapfile

" -- File Browser --
let g:netrw_liststyle = 3
let g:netrw_browse_split = 4
let g:netrw_winsize = 20

" -- Quick Save/Exit --
nnoremap <C-s> :w<CR>
inoremap <C-s> <Esc>:w<CR>
nnoremap <C-q> :q<CR>

" -- Line Movement --
nnoremap <A-j> :m .+1<CR>==
nnoremap <A-k> :m .-2<CR>==
inoremap <A-j> <Esc>:m .+1<CR>==gi
inoremap <A-k> <Esc>:m .-2<CR>==gi
vnoremap <A-j> :m '>+1<CR>gv=gv
vnoremap <A-k> :m '<-2<CR>gv=gv

" -- Lightline --
let g:lightline = {
    \ 'colorscheme': 'snazzy'
    \ }
